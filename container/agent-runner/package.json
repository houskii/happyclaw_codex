{
  "name": "happyclaw-agent-runner",
  "version": "1.0.0",
  "type": "module",
  "description": "Container-side agent runner for HappyClaw",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "npm --prefix ../agent-runner-core install",
    "prebuild": "if [ ! -d ../agent-runner-core/node_modules ]; then npm --prefix ../agent-runner-core install; fi && npm --prefix ../agent-runner-core run build",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.104",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@openai/codex-sdk": "^0.120.0",
    "cron-parser": "^5.0.0",
    "happyclaw-agent-runner-core": "file:../agent-runner-core",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/riba2534/happyclaw.git",
    "directory": "container/agent-runner"
  },
  "author": "riba2534",
  "keywords": [
    "claude-agent-sdk",
    "agent-runner",
    "mcp",
    "happyclaw"
  ]
}
